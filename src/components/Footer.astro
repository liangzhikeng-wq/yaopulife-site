---
const footerLinks = {
  Shop: ["Custom Gifts", "Home Decor", "Pet Portraits", "Party Decor"],
  Support: ["How It Works", "Shipping & Returns", "Privacy Policy", "Terms of Service"],
  Company: ["About Us", "Contact", "Blog"]
};
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-2xl font-bold text-white">yaopulife</a>
        <p class="mt-4 text-sm text-gray-400">Handpicked DIY, AI-Imagined Artistry.</p>
      </div>
      
      {Object.entries(footerLinks).map(([title, links]) => (
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider">{title}</h3>
          <ul class="mt-4 space-y-2">
            {links.map(link => (
              <li><a href="#" class="text-sm hover:text-white transition-colors">{link}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center">
      <p class="text-sm text-gray-500">© 2026 yaopulife DIY. All rights reserved.</p>
      <div class="mt-4 md:mt-0 flex space-x-6">
        <a href="#" class="text-gray-400 hover:text-white"><span class="sr-only">Instagram</span>IG</a>
        <a href="#" class="text-gray-400 hover:text-white"><span class="sr-only">Pinterest</span>PI</a>
        <a href="#" class="text-gray-400 hover:text-white"><span class="sr-only">TikTok</span>TK</a>
      </div>
    </div>
  </div>
</footer>
