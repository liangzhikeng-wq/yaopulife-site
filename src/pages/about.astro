---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="About" description="Learn about yaopulife DIY - where Chinese craftsmanship meets AI imagination. Custom handcrafted art made to order.">
  <Navbar />
  
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-gray-900">Our Story</h1>
      
      <div class="mt-8 prose prose-lg text-gray-600">
        <p class="text-xl leading-relaxed">
          yaopulife was born from a simple observation: some of the most creative DIY craftsmanship 
          in the world comes from China, yet much of it never reaches the people who would treasure it most.
        </p>
        
        <p>
          We bridge that gap by combining two powerful forces: the time-honored skills of Chinese 
          artisans — embroidery, needle felting, resin art, 3D printing — with cutting-edge AI design 
          technology that lets us visualize your custom ideas before a single thread is pulled.
        </p>
        
        <h2 class="text-2xl font-bold text-gray-900 mt-12">What Makes Us Different</h2>
        
        <ul class="mt-4 space-y-3">
          <li><strong>AI-Powered Previews:</strong> See exactly how your custom piece will look before you commit.</li>
          <li><strong>Real Artisans:</strong> Every item is handcrafted by skilled makers, not mass-produced.</li>
          <li><strong>Truly Custom:</strong> Colors, names, portraits, themes — if you can imagine it, we can create it.</li>
          <li><strong>Global Delivery:</strong> From our partner workshops to your door, anywhere in the world.</li>
        </ul>
        
        <h2 class="text-2xl font-bold text-gray-900 mt-12">Our Promise</h2>
        
        <p>
          We believe custom art should be accessible, transparent, and delightful. No hidden fees, 
          no surprises — just beautiful, personalized creations that tell your unique story.
        </p>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
