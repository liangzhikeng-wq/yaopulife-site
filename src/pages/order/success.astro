---
import Layout from "../../layouts/Layout.astro";

const sessionId = Astro.url.searchParams.get('session_id');
---

<Layout title="Order Confirmed - yaopulife" description="Your order has been confirmed">
  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="text-6xl mb-6">🎉</div>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">Order Confirmed!</h1>
      <p class="text-lg text-gray-600 mb-8">
        Thank you for your order. Your custom gift is being prepared with care.
      </p>
      
      {sessionId && (
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-8">
          <p class="text-sm text-green-800">
            Order ID: <span class="font-mono">{sessionId.slice(-12).toUpperCase()}</span>
          </p>
        </div>
      )}
      
      <div class="bg-gray-50 rounded-xl p-8 mb-8 text-left">
        <h2 class="text-lg font-semibold mb-4">What happens next?</h2>
        <ol class="space-y-4">
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-8 h-8 bg-brand-100 text-brand-600 rounded-full flex items-center justify-center font-bold">1</span>
            <div>
              <strong class="text-gray-900">Design Preview (24 hours)</strong>
              <p class="text-sm text-gray-600">We'll email you a custom design preview for your approval</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-8 h-8 bg-brand-100 text-brand-600 rounded-full flex items-center justify-center font-bold">2</span>
            <div>
              <strong class="text-gray-900">Your Approval</strong>
              <p class="text-sm text-gray-600">Review and approve the design (or request changes)</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-8 h-8 bg-brand-100 text-brand-600 rounded-full flex items-center justify-center font-bold">3</span>
            <div>
              <strong class="text-gray-900">Crafting (5-18 days)</strong>
              <p class="text-sm text-gray-600">Our artisans handcraft your unique piece</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-8 h-8 bg-brand-100 text-brand-600 rounded-full flex items-center justify-center font-bold">4</span>
            <div>
              <strong class="text-gray-900">Quality Check & Ship</strong>
              <p class="text-sm text-gray-600">Carefully packaged and shipped to your door</p>
            </div>
          </li>
        </ol>
      </div>
      
      <div class="flex gap-4 justify-center">
        <a href="/" class="px-6 py-3 bg-brand-600 text-white rounded-lg hover:bg-brand-700">
          Back to Home
        </a>
        <a href="/shop" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50">
          Continue Shopping
        </a>
      </div>
      
      <p class="mt-8 text-sm text-gray-500">
        Questions? Email us at <a href="mailto:support@yaopulife.com" class="text-brand-600 hover:underline">support@yaopulife.com</a>
      </p>
    </div>
  </section>
</Layout>