---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const categories = [
  { name: "Custom Gifts", desc: "One-of-a-kind presents", image: "/products/embroidery/emb-wedding-main.jpg" },
  { name: "Home Decor", desc: "AI-designed interiors", image: "/products/resin-coaster/rc-ocean-main.jpg" },
  { name: "Pet Portraits", desc: "Your furry friend, reimagined", image: "/products/needle-felt/nf-dog-main.jpg" },
  { name: "Party Decor", desc: "Celebrations elevated", image: "/products/moon-lamp/ml-text-main.jpg" }
];

const trustPoints = [
  { title: "Unique AI Design", desc: "Every piece starts with your idea, refined by AI" },
  { title: "Handcrafted to Order", desc: "Real artisans bring the vision to life" },
  { title: "Worldwide Shipping", desc: "From our workshop to your door, globally" }
];
---

<Layout title="Home" description="Discover handpicked DIY creations, reimagined with AI artistry. Custom gifts, home decor, and pet portraits made to order.">
  <Navbar />
  
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-brand-50 via-white to-orange-50 py-20 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight">
            Handpicked DIY,<br />
            <span class="text-brand-600">AI-Imagined Artistry</span>
          </h1>
          <p class="mt-6 text-lg text-gray-600 max-w-lg">
            Discover unique handcrafted creations from China's finest DIY artisans, 
            reimagined with cutting-edge AI design. Every piece tells your story.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/shop" class="inline-flex items-center px-6 py-3 text-base font-medium text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition-colors">
              Explore Collection
            </a>
            <a href="/how-it-works" class="inline-flex items-center px-6 py-3 text-base font-medium text-brand-600 bg-white border border-brand-200 rounded-lg hover:bg-brand-50 transition-colors">
              How It Works
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lg">
            <img src="/products/needle-felt/nf-cat-main.jpg" alt="Needle felted cat portrait - handcrafted DIY art" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -bottom-4 -left-4 w-32 h-32 rounded-xl overflow-hidden shadow-md border-2 border-white">
            <img src="/products/embroidery/emb-flower-main.jpg" alt="Floral embroidery hoop" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -top-4 -right-4 w-28 h-28 rounded-xl overflow-hidden shadow-md border-2 border-white">
            <img src="/products/moon-lamp/ml-photo-main.jpg" alt="Custom moon lamp" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Categories -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900">Shop by Category</h2>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {categories.map(cat => (
          <a href={`/shop?category=${cat.name.toLowerCase().replace(' ', '-')}`} class="group block bg-gray-50 rounded-xl overflow-hidden hover:bg-brand-50 transition-colors">
            <div class="aspect-[3/2] overflow-hidden">
              <img src={cat.image} alt={cat.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-4">
              <h3 class="text-lg font-semibold text-gray-900 group-hover:text-brand-600">{cat.name}</h3>
              <p class="mt-1 text-sm text-gray-500">{cat.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Trust -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        {trustPoints.map(point => (
          <div class="text-center">
            <div class="w-12 h-12 mx-auto bg-brand-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-gray-900">{point.title}</h3>
            <p class="mt-2 text-sm text-gray-500">{point.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 bg-brand-600">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to Create Something Unique?</h2>
      <p class="mt-4 text-brand-100">Share your idea and receive a free AI design preview within 24 hours.</p>
      <a href="/contact" class="mt-8 inline-flex items-center px-8 py-4 text-base font-medium text-brand-600 bg-white rounded-lg hover:bg-gray-100 transition-colors">
        Start Your Custom Order
      </a>
    </div>
  </section>
  
  <Footer />
</Layout>
