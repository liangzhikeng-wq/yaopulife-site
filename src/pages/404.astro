---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Page Not Found" description="The page you are looking for does not exist.">
  <Navbar />
  
  <section class="py-32 bg-white">
    <div class="max-w-xl mx-auto px-4 text-center">
      <h1 class="text-6xl font-bold text-brand-600">404</h1>
      <p class="mt-4 text-xl text-gray-600">This page doesn't exist, but your custom creation can.</p>
      <div class="mt-8 flex justify-center gap-4">
        <a href="/" class="px-6 py-3 text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition-colors">Go Home</a>
        <a href="/shop" class="px-6 py-3 text-brand-600 border border-brand-200 rounded-lg hover:bg-brand-50 transition-colors">Browse Shop</a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
