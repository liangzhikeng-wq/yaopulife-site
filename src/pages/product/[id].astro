---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export function getStaticPaths() {
  const products = [
    { id: "1", title: "Custom Pet Embroidery Hoop", price: "$48", category: "Pet Portraits", material: "Cotton thread on linen, wooden hoop", size: "8 inch diameter", time: "10-14 days", description: "A stunning hand-embroidered portrait of your beloved pet, stitched with care on premium linen fabric. Perfect for commemorating furry family members." },
    { id: "2", title: "Needle Felted Cat Portrait", price: "$65", category: "Pet Portraits", material: "100% wool roving, glass eyes", size: "6x6 inch shadow box", time: "14-18 days", description: "A three-dimensional needle-felted sculpture capturing your cat's unique personality. Each piece is meticulously shaped by hand using natural wool fibers." },
    { id: "3", title: "Personalized Family Name Sign", price: "$35", category: "Home Decor", material: "Basswood, non-toxic paint", size: "12x8 inches", time: "7-10 days", description: "A beautifully carved and painted wooden sign featuring your family name. Adds a warm, personal touch to any entryway or living space." },
    { id: "4", title: "DIY Resin Ocean Coasters", price: "$28", category: "Home Decor", material: "Epoxy resin, alcohol ink", size: "4x4 inches each (set of 4)", time: "5-7 days", description: "Mesmerizing ocean-wave coasters created with layered epoxy resin and alcohol inks. Each set is unique, like miniature seascapes for your table." },
    { id: "5", title: "Custom Wedding Embroidery", price: "$55", category: "Custom Gifts", material: "Silk thread on cotton", size: "10 inch diameter", time: "10-14 days", description: "Commemorate your special day with a bespoke embroidery featuring wedding flowers, dates, and names. A timeless keepsake for anniversaries." },
    { id: "6", title: "3D Printed Moon Lamp", price: "$42", category: "Home Decor", material: "PLA filament, LED base", size: "5.9 inch diameter", time: "5-7 days", description: "A realistic moon-shaped lamp printed from NASA lunar surface data. Warm LED glow creates ambient lighting perfect for bedrooms and nurseries." }
  ];
  return products.map(p => ({ params: { id: p.id }, props: p }));
}

const { title, price, category, material, size, time, description } = Astro.props;
---

<Layout title={title} description={description}>
  <Navbar />
  
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Image Gallery -->
        <div>
          <div class="aspect-square bg-gray-100 rounded-xl flex items-center justify-center">
            <span class="text-gray-400">{title} - Main Image</span>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-3">
            <div class="aspect-square bg-gray-100 rounded-lg flex items-center justify-center"><span class="text-xs text-gray-400">Scene</span></div>
            <div class="aspect-square bg-gray-100 rounded-lg flex items-center justify-center"><span class="text-xs text-gray-400">Detail</span></div>
            <div class="aspect-square bg-gray-100 rounded-lg flex items-center justify-center"><span class="text-xs text-gray-400">Size</span></div>
          </div>
        </div>
        
        <!-- Product Info -->
        <div>
          <p class="text-sm text-brand-600 font-medium">{category}</p>
          <h1 class="mt-2 text-3xl font-bold text-gray-900">{title}</h1>
          <p class="mt-4 text-2xl font-semibold text-brand-600">{price}</p>
          
          <div class="mt-6 prose text-gray-600">
            <p>{description}</p>
          </div>
          
          <div class="mt-8 space-y-3">
            <div class="flex"><span class="w-24 text-sm font-medium text-gray-500">Material</span><span class="text-sm text-gray-900">{material}</span></div>
            <div class="flex"><span class="w-24 text-sm font-medium text-gray-500">Size</span><span class="text-sm text-gray-900">{size}</span></div>
            <div class="flex"><span class="w-24 text-sm font-medium text-gray-500">Production</span><span class="text-sm text-gray-900">{time}</span></div>
          </div>
          
          <div class="mt-8">
            <a href="/contact" class="block w-full text-center px-8 py-4 text-lg font-medium text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition-colors">
              Request Custom Order
            </a>
            <p class="mt-3 text-center text-sm text-gray-500">Free AI design preview within 24 hours</p>
          </div>
        </div>
      </div>
      
      <!-- Process -->
      <div class="mt-16 border-t pt-12">
        <h2 class="text-2xl font-bold text-gray-900">How Your Custom Piece is Made</h2>
        <div class="mt-8 grid sm:grid-cols-4 gap-6">
          {[
            { step: "1", label: "You Share", desc: "Send photos, ideas, or descriptions" },
            { step: "2", label: "AI Preview", desc: "We create design previews in 24h" },
            { step: "3", label: "Crafting", desc: "Artisans handmake your approved design" },
            { step: "4", label: "Delivery", desc: "Quality checked & shipped worldwide" }
          ].map(s => (
            <div class="text-center">
              <div class="w-10 h-10 mx-auto bg-brand-100 text-brand-600 rounded-full flex items-center justify-center font-bold">{s.step}</div>
              <h3 class="mt-3 font-semibold text-gray-900">{s.label}</h3>
              <p class="mt-1 text-sm text-gray-500">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
