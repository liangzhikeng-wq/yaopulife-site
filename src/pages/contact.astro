---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact" description="Get in touch for custom orders, questions, or collaborations. We typically respond within 2 hours.">
  <Navbar />
  
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-bold text-gray-900">Get in Touch</h1>
        <p class="mt-4 text-lg text-gray-600">Have an idea? We'd love to hear it. Response time: within 2 hours on business days.</p>
      </div>
      
      <div class="mt-12 grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Send a Message</h2>
          <form class="mt-6 space-y-4" action="https://formspree.io/f/YOUR_FORM_ID" method="POST" enctype="multipart/form-data">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
              <input type="text" id="name" name="name" required class="mt-1 block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
              <input type="email" id="email" name="email" required class="mt-1 block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
            </div>
            <div>
              <label for="interest" class="block text-sm font-medium text-gray-700">Product Interest</label>
              <select id="interest" name="interest" class="mt-1 block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
                <option>Custom Gifts</option>
                <option>Home Decor</option>
                <option>Pet Portraits</option>
                <option>Party Decor</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700">Custom Requirements</label>
              <textarea id="message" name="message" rows="4" required class="mt-1 block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500"></textarea>
            </div>
            <div>
              <label for="file" class="block text-sm font-medium text-gray-700">Upload Reference Image (optional)</label>
              <input type="file" id="file" name="file" accept="image/*" class="mt-1 block w-full text-sm text-gray-500" />
            </div>
            <div class="flex items-start">
              <input type="checkbox" id="privacy" name="privacy" required class="mt-1 h-4 w-4 text-brand-600 border-gray-300 rounded" />
              <label for="privacy" class="ml-2 text-sm text-gray-600">I agree to the <a href="/privacy" class="text-brand-600 hover:underline">Privacy Policy</a></label>
            </div>
            <button type="submit" class="w-full px-6 py-3 text-base font-medium text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition-colors">
              Send Request
            </button>
          </form>
        </div>
        
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Other Ways to Reach Us</h2>
          <div class="mt-6 space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">Email</p>
                <p class="text-sm text-gray-600">hello@yaopulife.com</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">Live Chat</p>
                <p class="text-sm text-gray-600">Click the chat bubble (bottom right)</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
