---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categoryLabels: Record<string, string> = {
  "gift-guides": "Gift Guides",
  "diy-inspiration": "DIY Inspiration",
  "product-care": "Product Care",
  "behind-the-scenes": "Behind the Scenes",
};
---

<Layout title="Blog" description="Inspiration, guides, and stories about handcrafted DIY gifts. Tips for choosing the perfect custom present.">
  <Navbar />

  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
      <p class="mt-4 text-lg text-gray-600">Inspiration, ideas, and stories from the world of handcrafted DIY art.</p>

      {posts.length === 0 && (
        <p class="mt-12 text-gray-500">New articles coming soon. Stay tuned!</p>
      )}

      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            {post.data.image && (
              <div class="aspect-[3/2] overflow-hidden">
                <img src={post.data.image} alt={post.data.imageAlt || post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
            )}
            <div class="p-5">
              <p class="text-xs font-medium text-brand-600 uppercase tracking-wide">{categoryLabels[post.data.category] || post.data.category}</p>
              <h2 class="mt-2 text-lg font-semibold text-gray-900 group-hover:text-brand-600 line-clamp-2">{post.data.title}</h2>
              <p class="mt-2 text-sm text-gray-500 line-clamp-2">{post.data.description}</p>
              <time class="mt-3 block text-xs text-gray-400" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
