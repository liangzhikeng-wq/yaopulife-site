# Cloudflare
CF_API_TOKEN=REPLACE_ME
CF_ACCOUNT_ID=REPLACE_ME
CF_ZONE_ID=REPLACE_ME

# Cloudflare R2 (Image Hosting)
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET_NAME=yaopulife-images
R2_ENDPOINT=REPLACE_ME
R2_PUBLIC_URL=https://cdn.yaopulife.com

# Sanity CMS
SANITY_PROJECT_ID=REPLACE_ME
SANITY_DATASET=production
SANITY_API_TOKEN=REPLACE_ME

# Vercel (set via dashboard, not here)
# VERCEL_TOKEN=REPLACE_ME

# Email (Resend)
RESEND_API_KEY=REPLACE_ME
RESEND_FROM_EMAIL=hello@yaopulife.com

# Klaviyo
KLAVIYO_PUBLIC_API_KEY=REPLACE_ME
KLAVIYO_PRIVATE_API_KEY=REPLACE_ME

# Tidio
TIDIO_PUBLIC_KEY=REPLACE_ME

# Formspree (Contact form fallback)
FORMSPREE_FORM_ID=REPLACE_ME
